{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quaver",
  "version": "1.0.0",
  "identifier": "com.niall.quaver",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Quaver",
        "width": 625,
        "height": 720,
        "minWidth": 390,
        "minHeight": 540,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true
      },
      "csp": "default-src 'self'; connect-src 'self' asset: https://asset.localhost http://asset.localhost; media-src 'self' asset: https://asset.localhost http://asset.localhost; img-src 'self' asset: https://asset.localhost http://asset.localhost data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
